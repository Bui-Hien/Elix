"use client"

import { 
  Package, 
  ShoppingCart, 
  Users, 
  Plus,
  AlertTriangle,
  RefreshCw,
  Clock,
  CheckCircle,
} from "lucide-react"
import Link from "next/link"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { Button } from "@/components/ui/button"
import { Badge } from "@/components/ui/badge"
import { Avatar, AvatarFallback } from "@/components/ui/avatar"
import { Progress } from "@/components/ui/progress"
import { Tabs, TabsList, TabsTrigger } from "@/components/ui/tabs"
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select"
import {
  Area,
  AreaChart,
  ResponsiveContainer,
  XAxis,
  YAxis,
  Tooltip,
  CartesianGrid,
} from "recharts"
import { mockOrders, mockProducts, mockCustomers } from "@/lib/data"

// Wavy trend icon component - giong reference
function TrendIcon({ className }: { className?: string }) {
  return (
    <svg 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      strokeWidth="2" 
      strokeLinecap="round" 
      strokeLinejoin="round"
      className={className}
    >
      <path d="M2 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0" />
    </svg>
  )
}

// Chart data
const chartData = [
  { month: "Jan", value: 1800 },
  { month: "Feb", value: 2200 },
  { month: "Mar", value: 1900 },
  { month: "Apr", value: 2800 },
  { month: "May", value: 2400 },
  { month: "Jun", value: 3200 },
  { month: "Jul", value: 2900 },
  { month: "Aug", value: 3500 },
  { month: "Sep", value: 2700 },
  { month: "Oct", value: 3100 },
  { month: "Nov", value: 3800 },
  { month: "Dec", value: 4200 },
]

const recentOrders = mockOrders.slice(0, 5)
const topProducts = mockProducts.sort((a, b) => (b.sold || 0) - (a.sold || 0)).slice(0, 5)

export default function AdminDashboard() {
  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat("vi-VN", {
      style: "currency",
      currency: "VND",
      maximumFractionDigits: 0,
    }).format(amount)
  }

  const totalRevenue = mockOrders.reduce((sum, o) => sum + o.total, 0)
  const totalOrders = mockOrders.length
  const pendingOrders = mockOrders.filter(o => o.status === "PENDING" || o.status === "CONFIRMED").length
  const totalCustomers = mockCustomers?.length || 12

  const stats = [
    {
      name: "Tong san pham",
      value: mockProducts.length.toString(),
      change: "+12%",
      trend: "up" as const,
      icon: Package,
    },
    {
      name: "Ti le hoan thanh",
      value: "98.7%",
      change: "+0.3%",
      trend: "up" as const,
      icon: CheckCircle,
    },
    {
      name: "Cho xu ly",
      value: pendingOrders.toString(),
      change: "-2.1s",
      trend: "down" as const,
      icon: Clock,
    },
    {
      name: "Khach hang",
      value: totalCustomers.toLocaleString(),
      change: "+8.2%",
      trend: "up" as const,
      icon: Users,
    },
  ]

  return (
    <div className="space-y-6">
      {/* Page header */}
      <div className="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 className="text-2xl font-semibold tracking-tight text-gray-900">Dashboard Overview</h1>
          <p className="text-gray-500 mt-1">
            Theo doi hoat dong va hieu suat he thong
          </p>
        </div>
        <div className="flex items-center gap-3">
          <Select defaultValue="30days">
            <SelectTrigger className="w-[140px] bg-white border-gray-200 text-sm font-medium">
              <SelectValue placeholder="Thoi gian" />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="7days">7 ngay qua</SelectItem>
              <SelectItem value="30days">30 ngay qua</SelectItem>
              <SelectItem value="90days">90 ngay qua</SelectItem>
            </SelectContent>
          </Select>
          <Button className="bg-violet-600 hover:bg-violet-700 text-white font-medium">
            <Plus className="mr-2 h-4 w-4" />
            San pham moi
          </Button>
        </div>
      </div>

      {/* Quick Actions - giong reference */}
      <div className="grid gap-4 md:grid-cols-3">
        <Link href="/admin/products/new">
          <Card className="bg-white border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all cursor-pointer group">
            <CardContent className="flex items-center gap-4 p-5">
              <div className="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                <Plus className="h-6 w-6 text-emerald-500" />
              </div>
              <div>
                <p className="font-medium text-gray-900">Them san pham</p>
                <p className="text-sm text-gray-500">Tao san pham tu dong hoa moi</p>
              </div>
            </CardContent>
          </Card>
        </Link>
        <Link href="/admin/orders?status=PENDING">
          <Card className="bg-white border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all cursor-pointer group">
            <CardContent className="flex items-center gap-4 p-5">
              <div className="flex h-12 w-12 items-center justify-center rounded-xl bg-red-50 group-hover:bg-red-100 transition-colors">
                <AlertTriangle className="h-6 w-6 text-red-500" />
              </div>
              <div>
                <p className="font-medium text-gray-900">Don can duyet</p>
                <p className="text-sm text-gray-500">Kiem tra don hang that bai</p>
              </div>
            </CardContent>
          </Card>
        </Link>
        <Card className="bg-white border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all cursor-pointer group">
          <CardContent className="flex items-center gap-4 p-5">
            <div className="flex h-12 w-12 items-center justify-center rounded-xl bg-violet-50 group-hover:bg-violet-100 transition-colors">
              <RefreshCw className="h-6 w-6 text-violet-500" />
            </div>
            <div>
              <p className="font-medium text-gray-900">Chay lai that bai</p>
              <p className="text-sm text-gray-500">Thu lai cac thuc thi loi</p>
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Stats Grid - giong reference voi wavy icon */}
      <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {stats.map((stat) => (
          <Card key={stat.name} className="bg-white border border-gray-100">
            <CardContent className="p-5">
              <div className="flex items-start justify-between">
                <div className="flex h-11 w-11 items-center justify-center rounded-xl bg-gray-50 border border-gray-100">
                  <stat.icon className="h-5 w-5 text-gray-500" />
                </div>
                <div className={`flex items-center gap-1 text-sm font-medium ${
                  stat.trend === "up" ? "text-emerald-500" : "text-red-500"
                }`}>
                  <TrendIcon className="h-4 w-4" />
                  {stat.change}
                </div>
              </div>
              <div className="mt-4">
                <p className="text-3xl font-semibold tracking-tight text-gray-900">{stat.value}</p>
                <p className="text-sm text-gray-500 mt-1">{stat.name}</p>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>

      {/* Charts and Balance - giong reference */}
      <div className="grid gap-6 lg:grid-cols-3">
        {/* Performance Chart */}
        <Card className="lg:col-span-2 bg-white border border-gray-100">
          <CardHeader className="flex flex-row items-start justify-between space-y-0 pb-2">
            <div>
              <CardTitle className="text-base font-semibold text-gray-900">Phan tich hieu suat</CardTitle>
              <CardDescription className="text-gray-500 mt-1">
                Xu huong thuc thi va chi so he thong
              </CardDescription>
            </div>
            <Tabs defaultValue="workflows" className="w-auto">
              <TabsList className="bg-gray-100/80 p-1 h-9 gap-1">
                <TabsTrigger value="workflows" className="text-xs px-3 h-7 data-[state=active]:bg-white data-[state=active]:shadow-sm rounded-md">
                  Doanh thu
                </TabsTrigger>
                <TabsTrigger value="sales" className="text-xs px-3 h-7 data-[state=active]:bg-white data-[state=active]:shadow-sm rounded-md">
                  Don hang
                </TabsTrigger>
                <TabsTrigger value="views" className="text-xs px-3 h-7 data-[state=active]:bg-white data-[state=active]:shadow-sm rounded-md">
                  Luot xem
                </TabsTrigger>
              </TabsList>
            </Tabs>
          </CardHeader>
          <CardContent className="pt-6">
            <div className="h-[300px]">
              <ResponsiveContainer width="100%" height="100%">
                <AreaChart data={chartData} margin={{ top: 5, right: 10, left: -10, bottom: 5 }}>
                  <defs>
                    <linearGradient id="colorValue" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stopColor="#3b82f6" stopOpacity={0.15}/>
                      <stop offset="100%" stopColor="#3b82f6" stopOpacity={0}/>
                    </linearGradient>
                  </defs>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" vertical={false} />
                  <XAxis 
                    dataKey="month" 
                    axisLine={false}
                    tickLine={false}
                    tick={{ fill: '#94a3b8', fontSize: 12 }}
                    dy={10}
                  />
                  <YAxis 
                    axisLine={false}
                    tickLine={false}
                    tick={{ fill: '#94a3b8', fontSize: 12 }}
                    tickFormatter={(value) => `${value / 1000}k`}
                    dx={-10}
                  />
                  <Tooltip 
                    contentStyle={{ 
                      backgroundColor: 'white', 
                      border: '1px solid #e2e8f0',
                      borderRadius: '8px',
                      boxShadow: '0 4px 6px -1px rgba(0, 0, 0, 0.1)',
                      fontSize: '13px',
                    }}
                    formatter={(value: number) => [`${value.toLocaleString()}`, 'Gia tri']}
                  />
                  <Area
                    type="monotone"
                    dataKey="value"
                    stroke="#3b82f6"
                    strokeWidth={2}
                    fillOpacity={1}
                    fill="url(#colorValue)"
                  />
                </AreaChart>
              </ResponsiveContainer>
            </div>
          </CardContent>
        </Card>

        {/* Account Balance - giong reference */}
        <Card className="bg-white border border-gray-100">
          <CardHeader className="pb-2">
            <CardTitle className="text-base font-semibold text-gray-900">So du tai khoan</CardTitle>
          </CardHeader>
          <CardContent className="space-y-6">
            <div>
              <p className="text-4xl font-semibold tracking-tight text-gray-900">
                {formatCurrency(totalRevenue)}
              </p>
            </div>
            
            <div className="space-y-3">
              <div className="flex items-center justify-between text-sm">
                <span className="text-gray-500">Doanh thu thang</span>
                <span className="font-medium text-gray-900">{formatCurrency(50000000)}</span>
              </div>
              <div className="flex items-center justify-between text-sm">
                <span className="text-gray-500">Chi phi thang nay</span>
                <span className="font-medium text-gray-900">{formatCurrency(7675000)}</span>
              </div>
              <Progress value={15} className="h-2 bg-gray-100" />
            </div>

            <div className="flex gap-3 pt-2">
              <Button className="flex-1 bg-gray-900 hover:bg-gray-800 text-white font-medium h-10">
                Them credit
              </Button>
              <Button variant="outline" className="flex-1 border-gray-200 font-medium h-10 bg-transparent">
                Chuyen khoan
              </Button>
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Recent Activity - giong reference */}
      <Card className="bg-white border border-gray-100">
        <CardHeader className="flex flex-row items-center justify-between">
          <CardTitle className="text-base font-semibold text-gray-900">Hoat dong gan day</CardTitle>
          <Button variant="ghost" size="sm" className="text-violet-600 hover:text-violet-700 hover:bg-violet-50 font-medium" asChild>
            <Link href="/admin/orders">Xem tat ca</Link>
          </Button>
        </CardHeader>
        <CardContent>
          <div className="space-y-1">
            {recentOrders.map((order) => {
              const customerName = order.shippingAddress?.fullName || order.user?.name || 'Khach hang'
              const statusMap: Record<string, { label: string; className: string }> = {
                DELIVERED: { label: "Da giao", className: "bg-emerald-50 text-emerald-600 border-emerald-100" },
                PENDING: { label: "Cho xu ly", className: "bg-amber-50 text-amber-600 border-amber-100" },
                PAID: { label: "Da thanh toan", className: "bg-blue-50 text-blue-600 border-blue-100" },
                SHIPPED: { label: "Dang giao", className: "bg-violet-50 text-violet-600 border-violet-100" },
                CANCELLED: { label: "Da huy", className: "bg-red-50 text-red-600 border-red-100" },
              }
              const status = statusMap[order.status] || { label: order.status, className: "bg-gray-50 text-gray-600" }
              
              return (
                <div key={order.id} className="flex items-center gap-4 py-3 px-2 rounded-lg hover:bg-gray-50 transition-colors -mx-2">
                  <Avatar className="h-10 w-10 border border-gray-100">
                    <AvatarFallback className="bg-gradient-to-br from-violet-500 to-purple-600 text-white text-sm font-medium">
                      {customerName.charAt(0)}
                    </AvatarFallback>
                  </Avatar>
                  <div className="flex-1 min-w-0">
                    <p className="font-medium text-gray-900 truncate">{customerName}</p>
                    <p className="text-sm text-gray-500">
                      {new Date(order.createdAt).toLocaleDateString("vi-VN")} • #{(order.orderCode || order.id).slice(0, 6).toUpperCase()}
                    </p>
                  </div>
                  <div className="flex items-center gap-4">
                    <Badge variant="outline" className={`text-xs font-medium border ${status.className}`}>
                      {status.label}
                    </Badge>
                    <p className="font-semibold text-gray-900 min-w-[100px] text-right">
                      {formatCurrency(order.total)}
                    </p>
                  </div>
                </div>
              )
            })}
          </div>
        </CardContent>
      </Card>
    </div>
  )
}
